# Local development can run without Firebase by using the file-backed local store.
DATA_BACKEND=local

# Required for production Firebase/Firestore.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Required before production. Use a long random value.
SESSION_PASSWORD=change-this-long-random-secret

# Optional for AI Quick Entry. Without this, the app uses a local rule-based draft parser.
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash

# Optional for seed/import scripts.
SEED_USERS=Naufal:123456,Kolega:123456
IMPORT_USER_ID=import-script

